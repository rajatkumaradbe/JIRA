                  <picture>date{YYYY-MM-DD}</picture>
                  <message>
                     <text name="formatTest"/>
                  </message>
               </validate>
               <caption placement="top" reserve="3.18mm">
                  <value>
                     <text>Datum</text>
                  </value>
                  <font size="7pt" typeface="Arial"/>
               </caption>
               <assist>
                  <speak priority="caption"/>
               </assist>
               <event activity="ready" ref="$form" name="event__form_ready">
                  <script contentType="application/x-javascript">
// Dagens datum
var nu = new Date();
var yy = nu.getFullYear();
var mm = nu.getMonth() + 1;
var dd = nu.getDate();
var dat = this.rawValue;

if(mm &lt;= 9){
	mm = "0" + mm;
}

if(dd &lt;= 9){
	dd = "0" + dd;
}

if(dat == null)
{
	this.rawValue = yy + "" + mm + "" + dd;
	}else{
	this.rawValue = dat;
}
	
</script>
               </event>
               <bind match="none"/>
            </field>
