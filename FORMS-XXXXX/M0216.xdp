               <event activity="prePrint" ref="$host" name="event__prePrint">
                  <script contentType="application/x-javascript">
// Hämtar och presenterar dagens datum
var nu = new Date();
var yy = nu.getFullYear();
var mm = nu.getMonth() + 1;
var dd = nu.getDate();

if(mm &lt;= 9){
mm = "0" + mm;
}

if(dd &lt;= 9){
dd = "0" + dd;
}

// Hämtar och presenterar nuvarande tid
var hours = nu.getHours(); //Returnerar timmen, ett tal mellan 0 och 23
var minutes = nu.getMinutes(); //Returnerar minuten, ett tal mellan 0 och 59
var seconds = nu.getSeconds();

if (hours &lt;=9) {
	hours = "0" + hours;
} 
if (minutes &lt;=9) {
	minutes = "0" + minutes;
}
if (seconds &lt;=9) {
	seconds = "0" + seconds;
}

this.rawValue = "ID " + yy + "-" + mm + "-" + dd + " " + hours + ":" + minutes + ":" + seconds;
</script>
               </event>
